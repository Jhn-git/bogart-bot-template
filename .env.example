# (Required) Your Discord bot token
DISCORD_TOKEN=your_token_here

# (Optional) Restrict to specific servers for testing
# ALLOWED_GUILD_IDS=123456789,987654321

# (Optional) Path to quotes file (default: data/quotes.yaml)
# QUOTES_FILE=data/quotes.yaml

# (Optional) Seconds to wait before the first cycle after startup (default: 60)
# STARTUP_DELAY_SECONDS=60

# (Optional) Minutes between wandering cycles (default: 720 = 12 hours)
# DECISION_CYCLE_MINUTES=720

# (Optional) Minimum channel score to post (default: 50)
# MIN_SCORE_THRESHOLD=50

# (Optional) Logging level (default: INFO)
# LOG_LEVEL=INFO
